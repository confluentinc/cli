{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Generate Skills",
      "type": "shell",
      "command": "make generate-skills",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Validate Skills",
      "type": "shell",
      "command": "make validate-skills",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Build CLI with Skills",
      "type": "shell",
      "command": "make build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": ["Generate Skills", "Validate Skills"],
      "problemMatcher": ["$go"]
    },
    {
      "label": "Clean Skills",
      "type": "shell",
      "command": "make clean-skills",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
